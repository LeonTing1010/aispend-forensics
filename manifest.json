{
  "manifest_version": 3,
  "name": "AI-spend Forensics",
  "version": "0.1.2",
  "description": "Track and analyze your AI tool spending. Know where your money goes.",
  "permissions": [
    "storage",
    "notifications",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.cursor.com/*",
    "*://cursor.com/*",
    "*://*.anthropic.com/*",
    "*://*.replit.com/*",
    "*://replit.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "AI-spend Forensics",
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
